{
  "agent": {
    "model": "claude-4-6-sonnet",
    "temperature": 0.6,
    "maxTokens": 16000,
    "systemPrompt": "system.md",
    "tools": [
      { "method": "create-topic", "description": "tools/createTopic.md" },
      { "method": "get-dashboard-data", "description": "tools/getDashboardData.md" },
      { "method": "start-article", "description": "tools/startArticle.md" },
      { "method": "get-article", "description": "tools/getArticle.md" },
      { "method": "search-web", "description": "tools/searchWeb.md" }
    ],
    "webInterfacePath": "/chat"
  }
}
